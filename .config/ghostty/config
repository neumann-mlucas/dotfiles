#
# The template does not set any default options, since Ghostty ships
# with sensible defaults for all options. Users should only need to set
# options that they want to change from the default.
#
# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.
#

# background
background-blur = false
background-blur-radius = 100
background-opacity = 1.0

# misc
theme = Nord
bold-is-bright = true
cursor-style = block

# font stuff
font-family = FiraCode Nerd
font-size = 16

# clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = true

# shell integration
shell-integration = zsh
shell-integration-features = no-cursor,no-sudo,no-title

# windows settings
window-padding-balance = true
window-padding-x = 20,20
window-padding-y = 10,10

# Keybindings
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+plus=increase_font_size:1

# Scrolling (vim ctrl+u/d/g)
keybind = ctrl+shift+u=scroll_page_up
keybind = ctrl+shift+d=scroll_page_down

# Tabs
keybind = alt+shift+t=new_tab
keybind = alt+shift+]=next_tab
keybind = alt+shift+[=previous_tab
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6

# Splits (vim verbs: v=vertical, s=horizontal, hjkl=navigate)
keybind = alt+shift+v=new_split:right
keybind = alt+shift+s=new_split:down
keybind = alt+shift+h=goto_split:left
keybind = alt+shift+j=goto_split:down
keybind = alt+shift+k=goto_split:up
keybind = alt+shift+l=goto_split:right
keybind = alt+shift+q=close_surface
keybind = alt+shift+z=toggle_split_zoom
keybind = alt+shift+equal=equalize_splits

# Prompt navigation (vim j/k)
keybind = ctrl+shift+k=jump_to_prompt:-1
keybind = ctrl+shift+j=jump_to_prompt:1

# Clipboard (vim y/p)
keybind = alt+shift+y=copy_to_clipboard
keybind = alt+shift+p=paste_from_clipboard

# Misc
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+semicolon=toggle_command_palette
keybind = ctrl+shift+s=write_scrollback_file:copy

# ctrl  + shift + page_up         jump_to_prompt:-1
