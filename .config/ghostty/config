# super + ctrl  + left_bracket    goto_split:previous
# super + ctrl  + right_bracket   goto_split:next
#
# ctrl  + alt   + shift + j       write_screen_file:open
# ctrl  + shift + c               copy_to_clipboard
# ctrl  + shift + v               paste_from_clipboard

